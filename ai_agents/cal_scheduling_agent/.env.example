# Google API key used to authenticate Gemini 3 Flash requests. Get one free at https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Cal.com API key for reading and managing calendar data. Generate one at https://app.cal.com/settings/developer/api-keys
CALCOM_API_KEY=your_calcom_api_key_here

# Optional. Scopes availability checks to a specific event type. Find the ID in the URL when editing an event type on your Cal.com dashboard.
CALCOM_EVENT_TYPE_ID=
